{
  "name": "bot",
  "version": "1.0.0",
  "description": "VEX STL server Discord bot with slash commands and event handlers",
  "main": "src/index.ts",
  "scripts": {
    "predev": "tsx src/deploy-commands.ts",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "register:commands": "tsx src/deploy-commands.ts",
    "check-types": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.8.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@octokit/webhooks": "^14.2.0",
    "@stlvex/database": "workspace:*",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
