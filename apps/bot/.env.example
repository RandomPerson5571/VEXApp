# Required
DISCORD_TOKEN="your-bot-token"
DISCORD_CLIENT_ID="your-application-client-id"

# Optional (recommended for fast command updates in one server)
DISCORD_GUILD_ID="your-test-server-id"

# Webhook API (used by the web app and other services to trigger bot actions)
WEBHOOK_PORT="3001"
WEBHOOK_SECRET="generate-a-long-random-secret"

# Integration webhooks (loaded via dotenv in src/config.ts)
GITHUB_WEBHOOK_SECRET="github-webhook-secret-from-repo-settings"
FUSION_WEBHOOK_SECRET="aps-webhook-secret-from-token-registration"
