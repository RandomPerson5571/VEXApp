generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEAM_LEADER
  TEAM_MEMBER
}

enum EventType {
  LESSON
  TOURNAMENT
  CHECK_IN
  WORK_SESSION
}

enum DocType {
  PROGRAMMING
  CAD
  HARDWARE
  GENERAL
}

enum VerificationMethod {
  EMAIL
  DISCORD
  UNVERIFIED
}

model User {
  id           String          @id // Must match Supabase Auth UUID 1:1
  firstName    String
  lastName     String
  email        String          @unique
  discordId          String?            @unique // Optional at signup, can be linked later
  role               UserRole           @default(TEAM_MEMBER)
  isAdmin            Boolean            @default(false)
  verificationMethod VerificationMethod @default(UNVERIFIED)
  isVerified         Boolean            @default(false)
  teamId             String?
  team               Team?              @relation(fields: [teamId], references: [id])
  discordAccount     DiscordAccount?
  authoredDocs       Documentation[]    @relation("AuthoredDocs")
  notebookLogs       NotebookLog[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model DiscordAccount {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  discordId       String   @unique
  discordUsername String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([discordId])
}

model Team {
  id              String          @id @default(uuid())
  name            String
  number          String          @unique // e.g., "82855T"
  discordServerId String?         @unique
  discordRoleId   String?         @unique
  members         User[]
  events          Event[]         @relation("TeamEvents")
  notebookLogs    NotebookLog[]
  invites         Invite[]
  createdAt       DateTime        @default(now())
}

model Event {
  id          String    @id @default(uuid())
  name        String
  description String?
  location    String
  type        EventType @default(WORK_SESSION)
  startDate   DateTime
  endDate     DateTime
  teams       Team[]    @relation("TeamEvents") // Implicit many-to-many join table
  createdAt   DateTime  @default(now())
}

model Folder {
  id   String          @id @default(uuid())
  name String
  docs Documentation[]
}

model Documentation {
  id        String   @id @default(uuid())
  title     String
  type      DocType
  content   String
  folderId  String
  folder    Folder   @relation(fields: [folderId], references: [id])
  authors   User[]   @relation("AuthoredDocs")
  createdAt DateTime @default(now())
}

model NotebookLog {
  id          String   @id @default(uuid())
  description String
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model Invite {
  id        String     @id // Invite code used in join URL
  teamId    String
  team      Team       @relation(fields: [teamId], references: [id])
  maxUses   Int        @default(1)
  usesCount Int        @default(0)
  expiresAt DateTime
  createdAt DateTime   @default(now())

  @@index([teamId])
}

model AuthRateLimit {
  key       String   @id
  count     Int      @default(1)
  expiresAt DateTime

  @@index([expiresAt])
}
