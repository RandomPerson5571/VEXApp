generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEAM_LEADER
  TEAM_MEMBER
}

enum EventType {
  LESSON
  TOURNAMENT
  CHECK_IN
  WORK_SESSION
}

enum DayPlanType {
  BUILD
  CODING
  TESTING
}

enum DocType {
  PROGRAMMING
  CAD
  HARDWARE
  GENERAL
}

enum VerificationMethod {
  EMAIL
  DISCORD
  UNVERIFIED
}

model User {
  id           String          @id // Must match Supabase Auth UUID 1:1
  firstName    String
  lastName     String
  email        String          @unique
  discordId          String?            @unique // Optional at signup, can be linked later
  role               UserRole           @default(TEAM_MEMBER)
  isAdmin            Boolean            @default(false)
  verificationMethod VerificationMethod @default(UNVERIFIED)
  isVerified         Boolean            @default(false)
  teamId             String?
  team               Team?              @relation(fields: [teamId], references: [id])
  discordAccount     DiscordAccount?
  authoredDocs       Documentation[]    @relation("AuthoredDocs")
  notebookLogs       NotebookLog[]
  inventorySignOuts InventoryItemSignOut[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  createdTasks    Task[]           @relation("TaskCreator")
  taskAssignments TaskAssignment[]
  createdDayPlans TeamDayPlan[]

  notificationSettings NotificationSettings?
}

model NotificationSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  enableDiscordPushNotifs Boolean  @default(true)
  githubNotifsEnabled     Boolean  @default(false)
  githubEvents            String[] @default(["push", "pull_request"])
  fusionNotifsEnabled     Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DiscordAccount {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  discordId       String   @unique
  discordUsername String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([discordId])
}

model Team {
  id              String          @id @default(uuid())
  name            String
  number          String          @unique // e.g., "82855T"
  discordServerId String?         @unique
  discordRoleId   String?         @unique
  annoucementsChannelId String?
  members         User[]
  events          Event[]         @relation("TeamEvents")
  notebookLogs    NotebookLog[]
  inventorySignOuts InventoryItemSignOut[]
  tasks           Task[]
  invites         Invite[]
  githubIntegration TeamGitHubIntegration?
  fusionIntegration TeamFusionIntegration?
  dayPlans          TeamDayPlan[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model DiscordGuildSettings {
  guildId             String   @id
  generalMemberRoleId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TeamGitHubIntegration {
  id                 String   @id @default(uuid())
  teamId             String   @unique
  team               Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  repositoryId       Int?
  repositoryFullName String
  repositoryUrl      String?
  webhookId          String?
  installationId     Int?     // GitHub App installation ID

  isActive           Boolean  @default(true)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([repositoryFullName])
}

model TeamFusionIntegration {
  id          String   @id @default(uuid())
  teamId      String   @unique
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  projectUrn  String
  projectName String?
  hookId      String?

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectUrn])
}

model Event {
  id          String    @id @default(uuid())
  name        String
  description String?
  location    String
  type        EventType @default(WORK_SESSION)
  startDate   DateTime
  endDate     DateTime
  teams       Team[]    @relation("TeamEvents") // Implicit many-to-many join table
  createdAt   DateTime  @default(now())
}

model TeamDayPlan {
  id        String      @id @default(cuid())
  teamId    String      @map("team_id")
  team      Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  date      DateTime    @db.Date
  type      DayPlanType
  createdBy String?     @map("created_by")
  creator   User?       @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@unique([teamId, date])
  @@index([teamId])
  @@map("team_day_plans")
}

model Folder {
  id   String          @id @default(uuid())
  name String
  docs Documentation[]
}

model Documentation {
  id        String   @id @default(uuid())
  title     String
  type      DocType
  content   String
  folderId  String
  folder    Folder   @relation(fields: [folderId], references: [id])
  authors   User[]   @relation("AuthoredDocs")
  createdAt DateTime @default(now())
}

model NotebookLog {
  id          String   @id @default(uuid())
  description String
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Invite {
  id               String    @id // Invite code used in join URL
  teamId           String
  team             Team      @relation(fields: [teamId], references: [id])
  maxUses          Int       @default(1)
  usesCount        Int       @default(0)
  expiresAt        DateTime
  /// Supabase auth user id holding a signup reservation; profile may not exist yet.
  reservedByUserId String?
  reservedAt       DateTime?
  createdAt        DateTime  @default(now())

  @@index([teamId])
  @@index([reservedByUserId])
}

model AuthRateLimit {
  key       String   @id
  count     Int      @default(1)
  expiresAt DateTime

  @@index([expiresAt])
}

enum TaskType {
  Hardware
  Software
  CAD
  Other
}

enum TaskPriority {
  Low
  Medium
  High
}

enum TaskStatus {
  NotStarted
  InProgress
  Done
}

// Main Task Model
model Task {
  id           String        @id @default(cuid()) // or @default(autoincrement()) depending on your preference
  title        String
  description  String?       @db.Text
  type         TaskType
  status       TaskStatus    @default(NotStarted)
  priority     TaskPriority? @default(Medium)
  dueDate      DateTime?     @map("due_date")
  
  // Multi-tenant and Ownership
  teamId       String        @map("team_id")
  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  createdBy    String?       @map("created_by")
  creator      User?         @relation("TaskCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  // Many-to-Many via Explicit Junction Table
  assignments  TaskAssignment[]

  // Self-referencing relationship for Sub-tasks
  parentTaskId String?       @map("parent_task_id")
  parentTask   Task?         @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks     Task[]        @relation("SubTasks")

  // Timestamps
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([teamId])
  @@index([createdBy])
  @@index([parentTaskId])
  @@map("tasks")
}

// Junction Table for Task Assignees
model TaskAssignment {
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  // Relations
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId]) // Composite primary key prevents duplicate assignments
  @@index([userId])
  @@index([taskId])
  @@map("task_assignments")
}

model InventoryItem {
  id          String   @id @default(cuid())
  imageUrl    String?
  name        String
  description String?
  totalStock  Int      // Total units the organization owns
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  signOuts    InventoryItemSignOut[]
}

model InventoryItemSignOut {
  id              String        @id @default(cuid())
  inventoryItemId String
  teamId          String
  userId          String        // The specific person who physically grabbed it
  quantity        Int           @default(1) // How many they signed out
  signedOutAt     DateTime      @default(now())
  returnedAt      DateTime?     // Nullable: if null, the item is currently checked out

  // Relations
  item            InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  team            Team          @relation(fields: [teamId], references: [id])
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
  @@index([teamId])
  @@index([userId])
}