{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "globalDependencies": [".env", "pnpm-lock.yaml", "pnpm-workspace.yaml"],
    "globalEnv": [
      "NODE_ENV",
      "DATABASE_URL",
      "DIRECT_URL",
      "DISCORD_TOKEN",
      "DISCORD_CLIENT_ID",
      "NEXT_PUBLIC_SUPABASE_URL",
      "NEXT_PUBLIC_SUPABASE_ANON_KEY"
    ],
    "tasks": {
      "build": {
        "dependsOn": ["^build", "db:generate"],
        "inputs": ["$TURBO_DEFAULT$", ".env*"],
        "outputs": [
          "dist/**",
          ".next/**",
          "!.next/cache/**",
          "!.next/dev/**"
        ]
      },
      "dev": {
        "dependsOn": ["^build", "db:generate"],
        "cache": false,
        "persistent": true
      },
      "lint": {
        "dependsOn": ["^build"],
        "outputs": []
      },
      "check-types": {
        "dependsOn": ["^build", "db:generate"],
        "outputs": []
      },
      "test": {
        "dependsOn": ["^build", "db:generate"],
        "outputs": []
      },
      "clean": {
        "cache": false
      },
      "db:generate": {
        "cache": true,
        "inputs": ["prisma/schema.prisma"],
        "outputs": ["generated/prisma/**"]
      },
      "db:migrate": {
        "cache": false
      },
      "db:push": {
        "cache": false
      }
    }
  }
  